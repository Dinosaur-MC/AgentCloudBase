<!DOCTYPE html>
<html lang="zh-CN">
<head><title>管理面板</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root{--primary:#2563eb;--bg:#f1f5f9;--card:#fff;--border:#e2e8f0;--text:#1e293b;--muted:#64748b;--success:#16a34a;--danger:#dc2626;--tag-h:22px}
  *{margin:0;padding:0;box-sizing:border-box}
  body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:var(--bg);color:var(--text);padding:24px}
  .container{max-width:960px;margin:0 auto}
  .header{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px}
  .header h1{font-size:24px;font-weight:600}
  .nav a{color:var(--primary);text-decoration:none;font-size:14px;margin-left:16px}
  .nav a:hover{text-decoration:underline}

  /* ── 统计卡片 ── */
  .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:12px;margin-bottom:24px}
  .stat-card{background:var(--card);border-radius:10px;padding:16px;text-align:center;border:1px solid var(--border)}
  .stat-card .num{font-size:28px;font-weight:700;color:var(--primary)}
  .stat-card .label{font-size:12px;color:var(--muted);margin-top:4px}

  /* ── 区块 ── */
  .section{background:var(--card);border-radius:10px;border:1px solid var(--border);padding:20px;margin-bottom:20px}
  .section h3{font-size:16px;font-weight:600;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid var(--border)}

  /* ── 共享目录卡片 ── */
  .share-card{padding:16px;border:1px solid var(--border);border-radius:8px;margin-bottom:12px}
  .share-card:last-child{margin-bottom:0}
  .share-card .title-line{display:flex;align-items:center;gap:6px;flex-wrap:wrap;min-height:var(--tag-h)}
  .share-card .title-line .name{font-weight:600;font-size:14px;line-height:var(--tag-h)}

  /* ── 标签（统一高度） ── */
  .tag{display:inline-flex;align-items:center;padding:0 8px;height:var(--tag-h);border-radius:999px;font-size:11px;font-weight:600;line-height:1}
  .tag-on{background:#dcfce7;color:#15803d}
  .tag-off{background:#fef2f2;color:#dc2626}
  .tag-expired{background:#fef2f2;color:#dc2626}
  .perm-tag{display:inline-flex;align-items:center;padding:0 6px;height:var(--tag-h);border-radius:4px;font-size:10px;font-weight:600;line-height:1}
  .perm-on-tag{background:#dcfce7;color:#15803d}
  .perm-off-tag{background:#f1f5f9;color:#94a3b8}

  /* ── 元信息行（flex 对齐） ── */
  .share-meta{display:flex;align-items:center;flex-wrap:wrap;gap:4px 8px;font-size:12px;color:var(--muted);margin:5px 0;line-height:var(--tag-h)}
  .share-meta .path{font-family:SFMono-Regular,Menlo,monospace;color:var(--text);font-size:11px;background:#f1f5f9;padding:0 5px;border-radius:3px;overflow-wrap:break-word;word-break:break-word}
  .share-meta .key{font-family:SFMono-Regular,Menlo,monospace;font-size:11px}
  .share-meta .arr{font-size:14px;color:#94a3b8;font-weight:600}
  .share-meta .lbl{color:var(--muted)}

  /* ── 更新表单 ── */
  .update-form{margin-top:10px;background:#f8fafc;border-radius:var(--radius)}
  .update-form .form-row{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
  .update-form .form-row + .form-row{margin-top:8px}
  .update-form .field-group{display:flex;align-items:center;gap:6px;flex-wrap:wrap}
  .update-form label{font-size:12px;display:inline-flex;align-items:center;gap:3px;cursor:pointer;line-height:var(--tag-h)}
  .update-form label input[type="checkbox"]{margin:0}
  .update-form input[type="text"],
  .update-form input[type="date"]{padding:3px 8px;border:1px solid var(--border);border-radius:4px;font-size:12px;outline:none;height:26px;box-sizing:border-box}
  .update-form input:focus{border-color:var(--primary)}

  /* ── 按钮 ── */
  .btn{display:inline-flex;align-items:center;justify-content:center;gap:4px;padding:0 12px;height:26px;border:none;border-radius:var(--radius);font-size:12px;cursor:pointer;font-weight:500;line-height:1}
  .btn-primary{padding:0 20px;height:34px;background:var(--primary);color:#fff;font-size:13px}
  .btn-primary:hover{background:#1d4ed8}
  .btn-update{background:var(--success);color:#fff}
  .btn-update:hover{background:#15803d}
  .btn-delete{background:transparent;color:var(--danger);border:1px solid #fecaca}
  .btn-delete:hover{background:#fef2f2}

  /* ── 添加表单 ── */
  .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .form-grid label{font-size:13px;font-weight:500;display:block;margin-bottom:4px}
  .form-grid input{width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:var(--radius);font-size:13px;outline:none;box-sizing:border-box}
  .form-grid input:focus{border-color:var(--primary)}
  .form-full{grid-column:1/-1}
  .checkbox-group{display:flex;gap:12px;flex-wrap:wrap}
  .checkbox-group label{font-weight:400;display:flex;align-items:center;gap:4px;cursor:pointer;font-size:13px}
  .add-submit{margin-top:16px}
</style></head>
<body>
  <div class="container">
    <div class="header">
      <h1>管理面板</h1>
      <div class="nav">
        <a href="/admin/logs">日志</a>
        <a href="/admin/stats">统计</a>
        <a href="/admin/logout">登出</a>
      </div>
    </div>

    {% if stats %}
    <div class="stats">
      <div class="stat-card"><div class="num">{{ stats.shares_count }}</div><div class="label">共享目录</div></div>
      <div class="stat-card"><div class="num">{{ stats.log_entries }}</div><div class="label">日志条目</div></div>
      <div class="stat-card"><div class="num">{{ stats.log_shards }}</div><div class="label">日志分片</div></div>
      <div class="stat-card"><div class="num">{{ "%.2f"|format(stats.log_size_mb) }} MB</div><div class="label">日志 / 上限 {{ "%.0f"|format(stats.log_max_total_mb) }} MB</div></div>
    </div>
    {% endif %}

    <div class="section">
      <h3>共享目录</h3>
      {% for share in shares %}
      <div class="share-card">
        <div class="title-line">
          <span class="name">{{ share.name }}</span>
          {% if share.enabled %}
            <span class="tag tag-on">启用</span>
          {% else %}
            <span class="tag tag-off">停用</span>
          {% endif %}
          {% for key, label in [("list","list"),("read","read"),("write","write"),("delete","del"),("rename","ren")] %}
            <span class="perm-tag {{ 'perm-on-tag' if share.permissions[key] else 'perm-off-tag' }}">{{ label }}</span>
          {% endfor %}
        </div>

        <div class="share-meta">
          <span class="lbl">路径</span>
          <span class="path">{{ share.virtual_path }}</span>
          <span class="arr">&rarr;</span>
          <span class="path">{{ share.real_path }}</span>
          <span class="lbl">密钥</span>
          <span class="key">{{ share.access_key }}</span>
          {% if share.access_key_expires %}
            <span class="arr">|</span>
            <span class="lbl">过期</span>
            <span>{{ share.access_key_expires }}</span>
            {% set exp = share.access_key_expires %}
            {% if exp < now %}<span class="tag tag-expired">已过期</span>{% endif %}
          {% endif %}
        </div>

        <form class="update-form" method="post" action="/admin/shares/update/{{ share.id }}">
          <div class="form-row">
            <label><input type="checkbox" name="enabled" {% if share.enabled %}checked{% endif %}> 启用</label>
            <label><input type="checkbox" name="list_perm" {% if share.permissions.list %}checked{% endif %}> list</label>
            <label><input type="checkbox" name="read_perm" {% if share.permissions.read %}checked{% endif %}> read</label>
            <label><input type="checkbox" name="write_perm" {% if share.permissions.write %}checked{% endif %}> write</label>
            <label><input type="checkbox" name="delete_perm" {% if share.permissions.delete %}checked{% endif %}> delete</label>
            <label><input type="checkbox" name="rename_perm" {% if share.permissions.rename %}checked{% endif %}> rename</label>
          </div>
          <div class="form-row">
            <div class="field-group">
              <input name="access_key" type="text" placeholder="新密钥(留空不变)" value="" size="16">
              <input name="access_key_expires" type="date" value="{{ share.access_key_expires[:10] if share.access_key_expires else '' }}">
            </div>
            <button class="btn btn-delete" type="submit" formaction="/admin/shares/delete/{{ share.id }}" formmethod="post">删除</button>
            <button class="btn btn-update" type="submit">更新</button>
          </div>
        </form>
      </div>
      {% else %}
      <p style="color:var(--muted);font-size:14px;">暂无共享目录</p>
      {% endfor %}
    </div>

    <div class="section">
      <h3>添加新共享</h3>
      <form method="post" action="/admin/shares/add">
        <div class="form-grid">
          <div><label>名称</label><input name="name" required></div>
          <div><label>虚拟路径</label><input name="virtual_path" required placeholder="/mydata"></div>
          <div class="form-full"><label>真实路径</label><input name="real_path" required placeholder="/home/user/data"></div>
          <div class="form-full">
            <label>权限</label>
            <div class="checkbox-group">
              <label><input type="checkbox" name="list_perm" checked> list</label>
              <label><input type="checkbox" name="read_perm" checked> read</label>
              <label><input type="checkbox" name="write_perm"> write</label>
              <label><input type="checkbox" name="delete_perm"> delete</label>
              <label><input type="checkbox" name="rename_perm"> rename</label>
            </div>
          </div>
          <div class="form-full"><label>访问密钥</label><input name="access_key" required></div>
        </div>
        <div class="add-submit"><button class="btn btn-primary" type="submit">添加共享</button></div>
      </form>
    </div>
  </div>
</body>
</html>
