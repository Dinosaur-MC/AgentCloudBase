<!DOCTYPE html>
<html lang="zh-CN">
<head><title>访问日志</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root{--primary:#3b82f6;--bg:#0f172a;--surface:#1e293b;--card:#1e293b;--border:#334155;--text:#e2e8f0;--muted:#94a3b8;--tag-h:22px;--radius:6px}
  *{margin:0;padding:0;box-sizing:border-box}
  body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:var(--bg);color:var(--text);padding:24px}
  .container{max-width:1100px;margin:0 auto}
  .header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px}
  .header h1{font-size:22px;font-weight:600}
  .header a{color:var(--primary);text-decoration:none;font-size:14px}
  .header a:hover{color:#60a5fa;text-decoration:underline}
  .filter-form{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:14px;margin-bottom:14px;display:flex;flex-wrap:wrap;gap:8px;align-items:end}
  .filter-form .f{display:flex;flex-direction:column;gap:2px}
  .filter-form .f label{font-size:11px;color:var(--muted)}
  .filter-form select,.filter-form input{padding:5px 8px;background:#0f172a;border:1px solid var(--border);border-radius:6px;font-size:13px;outline:none;color:var(--text)}
  .filter-form select:focus,.filter-form input:focus{border-color:var(--primary)}
  .filter-form button{padding:6px 16px;background:var(--primary);color:#fff;border:none;border-radius:6px;font-size:13px;cursor:pointer}
  .filter-form button:hover{background:#2563eb}
  .filter-form .reset{font-size:13px;color:var(--muted);padding:6px}
  .filter-form .reset:hover{color:var(--text)}
  .tw{background:var(--card);border:1px solid var(--border);border-radius:10px;overflow:hidden}
  table{width:100%;border-collapse:collapse;font-size:13px}
  th{background:#0f172a;text-align:left;padding:9px 12px;font-weight:600;border-bottom:1px solid var(--border);white-space:nowrap;color:var(--muted)}
  td{padding:7px 12px;border-bottom:1px solid #1e293b}
  tr:last-child td{border-bottom:none}
  tr:hover td{background:rgba(255,255,255,.03)}
  .ld{font-size:11px;color:var(--muted);max-width:250px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .empty{text-align:center;padding:40px;color:var(--muted)}
  .pg{padding:12px;display:flex;justify-content:center;align-items:center;gap:12px;font-size:13px}
  .pg a{color:var(--primary);text-decoration:none}
  .pg a:hover{color:#60a5fa}
  .badge{display:inline-flex;align-items:center;padding:0 8px;height:20px;border-radius:4px;font-size:10px;font-weight:600;line-height:1}
  .badge-request{background:rgba(59,130,246,.2);color:#60a5fa}
  .badge-access{background:rgba(34,197,94,.2);color:#34d399}
  .badge-access_denied{background:rgba(239,68,68,.2);color:#f87171}
  .badge-admin_login{background:rgba(168,85,247,.2);color:#c084fc}
  .badge-share_added,.badge-share_deleted,.badge-share_updated{background:rgba(34,211,238,.2);color:#22d3ee}
  .badge-file_uploaded,.badge-file_deleted,.badge-file_renamed{background:rgba(234,179,8,.2);color:#facc15}
  .badge-dir_created{background:rgba(249,115,22,.2);color:#fb923c}
  code{font-family:SFMono-Regular,Menlo,monospace;font-size:12px}
</style></head>
<body>
  <div class="container">
    <div class="header">
      <h1>访问日志</h1>
      <div>
        <a href="/admin/logs/live" style="margin-right:12px">实时模式</a>
        <a href="/admin">返回管理</a>
      </div>
    </div>

    <form class="filter-form" method="get">
      <div class="f">
        <label>操作</label>
        <select name="action">
          <option value="">全部</option>
          <option value="request" {{ 'selected' if action=='request' }}>请求</option>
          <option value="access" {{ 'selected' if action=='access' }}>访问</option>
          <option value="access_denied" {{ 'selected' if action=='access_denied' }}>拒绝</option>
          <option value="admin_login" {{ 'selected' if action=='admin_login' }}>登录</option>
          <option value="share_added" {{ 'selected' if action=='share_added' }}>添加共享</option>
          <option value="share_deleted" {{ 'selected' if action=='share_deleted' }}>删除共享</option>
          <option value="file_uploaded" {{ 'selected' if action=='file_uploaded' }}>上传</option>
          <option value="file_deleted" {{ 'selected' if action=='file_deleted' }}>删除</option>
          <option value="dir_created" {{ 'selected' if action=='dir_created' }}>创建目录</option>
          <option value="file_renamed" {{ 'selected' if action=='file_renamed' }}>重命名</option>
        </select>
      </div>
      <div class="f"><label>路径</label><input name="path" value="{{ path_filter }}"></div>
      <div class="f"><label>IP</label><input name="ip" value="{{ ip_filter }}"></div>
      <div class="f"><label>关键词</label><input name="keyword" value="{{ keyword }}"></div>
      <div class="f"><label>从</label><input name="date_from" type="date" value="{{ date_from }}"></div>
      <div class="f"><label>到</label><input name="date_to" type="date" value="{{ date_to }}"></div>
      <button type="submit">筛选</button>
      <a href="/admin/logs" class="reset">重置</a>
    </form>

    <div class="tw">
      <table>
        <thead><tr><th>时间</th><th>操作</th><th>路径</th><th>IP</th><th>状态</th><th>详情</th></tr></thead>
        <tbody>
        {% for log in logs %}
        <tr>
          <td style="white-space:nowrap;font-size:12px">{{ log.timestamp }}</td>
          <td><span class="badge badge-{{ log.action }}">{{ log.action }}</span></td>
          <td><code>{{ log.get('path','') }}</code></td>
          <td>{{ log.get('ip','') }}</td>
          <td>{{ log.get('status',log.get('duration_ms','')) }}</td>
          <td class="ld">{{ log }}</td>
        </tr>
        {% endfor %}
        {% if logs|length==0 %}
        <tr><td colspan="6" class="empty">无匹配日志</td></tr>
        {% endif %}
        </tbody>
      </table>
      <div class="pg">
        {% if page>1 %}<a href="?page={{page-1}}&action={{action}}&path={{path_filter}}&ip={{ip_filter}}&keyword={{keyword}}&date_from={{date_from}}&date_to={{date_to}}">上一页</a>{% endif %}
        <span>第 {{ page }}/{{ total_pages }} 页 | {{ total_logs }} 条</span>
        {% if page<total_pages %}<a href="?page={{page+1}}&action={{action}}&path={{path_filter}}&ip={{ip_filter}}&keyword={{keyword}}&date_from={{date_from}}&date_to={{date_to}}">下一页</a>{% endif %}
      </div>
    </div>
  </div>
</body>
</html>
