<!DOCTYPE html>
<html lang="zh-CN">

<head>
    <title>{{ filename }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="/static/viewer.css">
    <!-- Note: You are viewing this content in web page mode. Use `raw=1` parameter to view this content in raw mode. -->
</head>

<body>
    <div class="container">
        <div class="card">
            <div class="ch">
                <h2>{{ filename }}</h2>
                <div class="meta">{{ size|filesizeformat }} | {{ modified }}</div>
            </div>
            {% if can_write or can_delete or can_rename %}
            <div class="toolbar">
                {% if can_write %}
                <form method="post" action="/s/{{ path }}?key={{ key }}" enctype="multipart/form-data">
                    <input type="file" name="file" required>
                    <button type="submit">替换</button>
                </form>
                {% endif %}
                {% if can_delete %}
                <a href="/s/{{ path }}?key={{ key }}&delete=1" onclick="return confirm('删除 {{ filename }}？')"><button
                        class="dng">删除</button></a>
                {% endif %}
                {% if can_rename %}
                <form method="get" action="/s/{{ path }}">
                    <input name="key" type="hidden" value="{{ key }}">
                    <input name="rename_to" placeholder="新名称" required>
                    <button type="submit">重命名</button>
                </form>
                {% endif %}
                <a href="/s/{{ path }}?key={{ key }}&raw=1"><button class="out">原始</button></a>
                <a href="/s/{{ path }}?key={{ key }}&download=1"><button class="out">下载</button></a>
                <a href="/s/{{ path.rsplit('/',1)[0] }}?key={{ key }}"><button class="out">上级</button></a>
            </div>
            {% elif is_text %}
            <div class="toolbar">
                <a href="/s/{{ path }}?key={{ key }}&raw=1"><button class="out">原始</button></a>
                <a href="/s/{{ path }}?key={{ key }}&download=1"><button class="out">下载</button></a>
                <a href="/s/{{ path.rsplit('/',1)[0] }}?key={{ key }}"><button class="out">上级</button></a>
            </div>
            {% endif %}
            <div class="ca">
                {% if is_text %}
                <pre>{{ content|e }}</pre>
                {% else %}
                <div class="bn">
                    <p>二进制文件，无法预览</p>
                    <p style="margin-top:8px"><a href="/s/{{ path }}?key={{ key }}&download=1">点击下载</a></p>
                </div>
                {% endif %}
            </div>
            <div class="cf">
                {% if is_text %}<span>{{ line_count }} 行</span><span>|</span>{% endif %}
                <span>访问 {{ view_count }} 次</span><span>|</span>
                <a href="/help?level=basic">帮助</a>
            </div>
        </div>
    </div>
</body>

</html>