<!DOCTYPE html>
<html lang="zh-CN">
<head><title>管理员登录</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root{--primary:#3b82f6;--bg:#0f172a;--surface:#1e293b;--card:#1e293b;--border:#334155;--text:#e2e8f0;--muted:#94a3b8;--radius:6px}
  *{margin:0;padding:0;box-sizing:border-box}
  body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:var(--bg);color:var(--text);display:flex;align-items:center;justify-content:center;min-height:100vh}
  .login-card{background:var(--card);border-radius:12px;border:1px solid var(--border);padding:40px;width:360px;max-width:90vw}
  h1{font-size:20px;font-weight:600;text-align:center;margin-bottom:24px}
  label{display:block;font-size:14px;font-weight:500;margin-bottom:6px;color:var(--muted)}
  input{width:100%;padding:10px 12px;background:#0f172a;border:1px solid var(--border);border-radius:8px;font-size:14px;outline:none;color:var(--text)}
  input:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(59,130,246,.15)}
  button{width:100%;margin-top:16px;padding:10px;background:var(--primary);color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:500;cursor:pointer}
  button:hover{background:#2563eb}
  .error{color:#f87171;font-size:13px;text-align:center;margin-bottom:12px;padding:8px;background:#450a0a;border:1px solid #7f1d1d;border-radius:6px}
</style></head>
<body>
  <div class="login-card">
    <h1>管理面板</h1>
    {% if error %}<div class="error">{{ error }}</div>{% endif %}
    <form method="post" action="/admin/login">
      <label for="key">管理员密钥</label>
      <input type="password" name="key" id="key" placeholder="输入管理员密钥" required autofocus>
      <button type="submit">登录</button>
    </form>
  </div>
</body>
</html>
